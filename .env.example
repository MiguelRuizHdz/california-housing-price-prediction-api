# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Model Configuration
MODEL_PATH=models/california_housing_model.pkl
MODEL_VERSION=1.0.0
PREDICTION_THRESHOLD=0.5

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=california_housing
MLFLOW_ARTIFACT_ROOT=mlruns

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# Application Settings
APP_NAME=California Housing API
APP_VERSION=1.0.0
DEBUG_MODE=false

# Data Configuration
DATA_PATH=data
OUTPUT_PATH=outputs

# Model Training
RANDOM_STATE=42
TEST_SIZE=0.2
N_ESTIMATORS=100
MAX_DEPTH=10
